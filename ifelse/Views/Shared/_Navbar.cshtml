        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>

    <div class="offcanvas-body">

        <ul class="navbar-nav justify-content-end menu-list list-unstyled d-flex gap-md-3 mb-0">
            <li class="nav-item border-dashed active">
                <a href="#maincourse" class="nav-link d-flex align-items-center gap-3 text-dark p-2">
                    <svg width="24" height="24" viewBox="0 0 24 24"><use xlink:href="#maincourse"></use></svg>
                    <span>Main Course</span>
                </a>
            </li>
            <li class="nav-item border-dashed">
                <a href="#snack" class="nav-link d-flex align-items-center gap-3 text-dark p-2">
                    <svg width="24" height="24" viewBox="0 0 24 24"><use xlink:href="#snack"></use></svg>
                    <span>Snack</span>
                </a>
            </li>
            <li class="nav-item border-dashed">
                <a href="#dessert" class="nav-link d-flex align-items-center gap-3 text-dark p-2">
