    </div>

</div>

<header>
    <div class="container-fluid">
        <div class="row py-3 border-bottom">

            <div class="col-sm-4 col-lg-2 text-center text-sm-start d-flex gap-3 justify-content-center justify-content-md-start">
                <div class="d-flex align-items-center my-3 my-sm-0">
                    <a>
                        <img src="images/logo.svg" alt="logo" class="img-fluid">
                    </a>
                </div>
                <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasNavbar"
                        aria-controls="offcanvasNavbar">
                    <svg width="24" height="24" viewBox="0 0 24 24"><use xlink:href="#menu"></use></svg>
                </button>
            </div>


            <div class="col-lg-4">
                <ul class="navbar-nav list-unstyled d-flex flex-row gap-3 gap-lg-5 justify-content-center flex-wrap align-items-center mb-0 fw-bold text-uppercase text-dark">
                    <li class="nav-item active">
                        <a href="#" class="nav-link">Home</a>
                    </li>
                </ul>
            </div>

            <div class="col-sm-8 col-lg-2 d-flex gap-5 align-items-center justify-content-center justify-content-sm-end">
                <ul class="d-flex justify-content-end list-unstyled m-0">
                    <li>
                        <button type="button" class="btn btn-primary rounded-1" onclick="openLogin()">Login</button>

                        <div id="overlay" onclick="closeLogin()"
                             style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:999;"></div>

                        <div id="loginPopup" style="display:none;position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);width:350px;background:white;border-radius:6px;box-shadow:0 .25rem .75rem rgba(0,0,0,.3); z-index:1000;overflow:hidden">

                            <div class="tab-header" style="display:flex;border-bottom:1px solid #ddd;">
                                <div id="TabLogin" class="tab active" onclick="toLogin()">LOGIN</div>
                                <div id="TabRegister" class="tab" onclick="toRegister()">REGISTER</div>
                            </div>

                            <span onclick="closeLogin()"
                                  style="position:absolute;top:8px;right:10px;cursor:pointer;">❌</span>

                            <div class="slides" id="slides" style="display:flex;width:700px;transition:.4s">

                                <div class="slide" style="width:350px;padding:20px;">
                                    @if (TempData["LoginError"] != null)
                                    {
                                        <div class="alert alert-danger mb-3">

                                            @TempData["LoginError"]

                                        </div>
                                    }
                                    <form method="post" action="/Login">
                                        <label>Username</label>
                                        <input class="form-control mb-3" type="text" name="username">

                                        <label>Password</label>
                                        <input class="form-control mb-3" type="password" name="password">

                                        <button class="btn btn-primary rounded-1 w-100">Login</button>
                                    </form>
                                </div>

                                <div class="slide" style="width:350px;padding:20px;">
                                    <form method="post" action="/Login/Register">

                                        <label>Nama Lengkap</label>
                                        <input class="form-control mb-3" type="text" name="fullname" required>

                                        <label>Username</label>
                                        <input class="form-control mb-3" type="text" name="username" required>

                                        <label>Password</label>
                                        <input class="form-control mb-3" type="password" name="password" required>

                                        <label>Nomor HP</label>
                                        <input class="form-control mb-3" type="text" name="phone" required>

                                        <label>Email</label>
                                        <input class="form-control mb-3" type="text" name="email" required>

                                        <button class="btn btn-primary rounded-1 w-100">Daftar Member</button>

                                    </form>
                                </div>

                            </div>
                        </div>
                    </li>
                    <li>
                        <a class="p-2 mx-1">
                            <svg width="24" height="24"><use xlink:href="#user"></use></svg>
                        </a>
                    </li>
                    <li>
                        <a href="#" class="p-2 mx-1">
                            <svg width="24" height="24"><use xlink:href="#wishlist"></use></svg>
                        </a>
                    </li>
                    <li>
                        <a href="#" class="p-2 mx-1" data-bs-toggle="offcanvas" data-bs-target="#offcanvasCart" aria-controls="offcanvasCart">
                            <svg width="24" height="24"><use xlink:href="#shopping-bag"></use></svg>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</header>
<style>
                        .tab-header {
                        display: flex;
                        border-bottom: 1px solid #ddd;
                        background: #f9f9f9;
                        }

                        .tab {
                        flex: 1;
                        text-align: center;
                        padding: 12px 0;
                        cursor: pointer;
                        font-weight: bold;
                        color: #666;
                        transition: 0.3s;
                        position: relative;
                        }

                        .tab:hover {
                        color: #27714E;
                        }

                        .tab.active {
                        color: #27714E;
                        }

                        .tab.active::after {
                        content: "";
                        position: absolute;
                        bottom: 0;
                        left: 20%;
                        width: 60%;
                        height: 3px;
                        background: #27714E;
                        border-radius: 2px;
                        }

                        .slides {
                        display: flex;
                        width: 700px; 
                        transition: transform 0.4s ease;
                        }

                        .slide {
                        width: 350px;
                        padding: 20px;
                        box-sizing: border-box;
                        }

                        #loginPopup input {
                        width: 100%;
                        padding: 8px;
                        border: 1px solid #ccc;
                        border-radius: 4px;
                        }

                        #loginPopup button {
                        border-radius: 4px;
                        }

                        </style>
<script>
    const slides = document.getElementById("slides");

    function openLogin() {
        document.getElementById("overlay").style.display = "block";
        document.getElementById("loginPopup").style.display = "block";
        toLogin();
    }

    function closeLogin() {
        document.getElementById("overlay").style.display = "none";
        document.getElementById("loginPopup").style.display = "none";
    }

    function toLogin() {
        slides.style.transform = "translateX(0)";
        document.getElementById("TabLogin").classList.add("active");
        document.getElementById("TabRegister").classList.remove("active");
    }

    function toRegister() {
        slides.style.transform = "translateX(-350px)";
        document.getElementById("TabRegister").classList.add("active");
        document.getElementById("TabLogin").classList.remove("active");
    }

    @if (TempData["LoginError"] != null)
    {
            <text>
                window.onload = function () {
                    openLogin();
                };
            </text>
    }

        @if (TempData["RegisterError"] != null)
    {
            <text>
                window.onload = function () {
                    openLogin();
                    toRegister();
                };
            </text>
    }

</script>