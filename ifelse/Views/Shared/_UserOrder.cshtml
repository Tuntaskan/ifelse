<!-- Cart -->

<div class="card p-3 mt-5">

    <h4>Cart</h4>

    @if (Model.Cart != null && Model.Cart.Any())
    {
        foreach (var item in Model.Cart)
        {
            <p>
                @item.MenuName
                x @item.Qty
                =
                Rp @item.Subtotal.ToString("#,##0").Replace(",", ".")
            </p>
        }

        <hr />

        <button type="button"
                onclick="openPaymentPopup()"
                class="btn btn-primary rounded-1">

            Checkout

        </button>
    }
    else
    {
        <p>Cart kosong</p>
    }

</div>


<!-- PAYMENT POPUP -->
<div id="paymentPopup"
     style="display:none;
            position:fixed;
            top:50%;
            left:50%;
            transform:translate(-50%,-50%);
            background:white;
            padding:30px;
            border-radius:12px;
            z-index:9999;
            width:400px;">

    <h3>Checkout</h3>

    <form asp-controller="UserOrder"
          asp-action="Checkout"
          method="post">

        @{
            var roleId = Context.Session.GetInt32("roleId");
            var fullName = Context.Session.GetString("fullname");
        }

        @if (roleId == 6)
        {
            <!-- MEMBER -->
            <input type="text"
                   name="customerName"
                   value="@fullName"
                   class="form-control mb-2"
                   readonly />
        }
        else
        {
            <!-- GUEST -->
            <input type="text"
                   name="customerName"
                   placeholder="Nama Anda"
                   class="form-control mb-2"
                   required />
        }

        <input type="text"
               name="customerRequest"
               placeholder="Request (opsional)"
               class="form-control mb-2" />

        @if (roleId == 6)
        {
            <h5>Pilih Meja</h5>

            <div class="d-flex flex-wrap gap-2 mb-3">

                @foreach (var meja in Model.Tables)
                {
                    var isBooked =
                    meja.Status == "Booked"
                    || meja.Status == "Occupied";

                    <label>

                        <input type="radio"
                               name="tableId"
                               value="@meja.TableId"
                               hidden
                               @(isBooked ? "disabled" : "") />

                        <div class="seat-box
                            @(isBooked ? "seat-full" : "seat-empty")">

                            @meja.TableNumber

                        </div>

                    </label>
                }

            </div>
        }

        <select id="paymentMethod"
                name="paymentMethod"
                class="form-control mb-3">

            <option value="Cash">
                Cash
            </option>

            <option value="QRIS">
                QRIS
            </option>

        </select>

        <!-- QR -->
        <div id="qrisSection"
             style="display:none; text-align:center;">

            <h5>Scan QRIS</h5>

            <img src="~/images/qris.png"
                 width="200" />

        </div>

        <button type="submit"
                class="btn btn-primary w-100">
            Confirm Order
        </button>

        <button type="button"
                onclick="closePaymentPopup()"
                class="btn btn-secondary w-100 mt-2">

            Close

        </button>

    </form>

</div>



<!-- RECEIPT POPUP -->
<div id="receiptPopup"
     style="display:none;
            position:fixed;
            top:50%;
            left:50%;
            transform:translate(-50%,-50%);
            background:white;
            padding:30px;
            border-radius:12px;
            z-index:9999;
            width:400px;">

    <h3>Receipt</h3>

    @if (Model.LastOrderId != null)
    {
        <p>
            Order ID:
            #@Model.LastOrderId
        </p>

        @foreach (var item in Model.Cart)
        {
            <p>
                @item.MenuName
                x @item.Qty
                =
                Rp @item.Subtotal.ToString("#,##0").Replace(",", ".")
            </p>
        }

        <hr />

        <p>
            Total:
            Rp @Model.Cart.Sum(x => x.Subtotal).ToString("#,##0").Replace(",", ".")
        </p>
    }

    <button onclick="closeReceipt()"
            class="btn btn-primary">

        Close

    </button>

</div>



<script>

    function openPaymentPopup() {
        document
            .getElementById("paymentPopup")
            .style.display = "block";
    }

    function closePaymentPopup() {
        document
            .getElementById("paymentPopup")
            .style.display = "none";
    }

    function closeReceipt() {
        document
            .getElementById("receiptPopup")
            .style.display = "none";
    }

    // QRIS show/hide
    document.addEventListener("DOMContentLoaded", function () {

        let paymentDropdown =
            document.getElementById("paymentMethod");

        if (paymentDropdown) {

            paymentDropdown.addEventListener("change", function () {

                let qris =
                    document.getElementById("qrisSection");

                if (this.value == "QRIS") {
                    qris.style.display = "block";
                }
                else {
                    qris.style.display = "none";
                }

            });

        }

        // receipt popup after checkout
        @if (Model.LastOrderId != null)
        {
                <text>
                    document
                        .getElementById("receiptPopup")
                        .style.display = "block";
                </text>
        }

    });

</script>

<style>
    .seat-box {
        width: 60px;
        height: 60px;
        border-radius: 12px;
        display: flex;
        justify-content: center;
        align-items: center;
        cursor: pointer;
        font-weight: bold;
        border: 2px solid #ddd;
    }

    .seat-empty {
        background: #fff;
    }

    .seat-full {
        background: #ddd;
        cursor: not-allowed;
        opacity: 0.5;
    }

    input[type=radio]:checked + .seat-box {
        border: 2px solid #27714E;
        transform: scale(1.05);
    }
</style>