@model ifelse.Models.OrderPageViewModel
@using ifelse.Models

<section id="maincourse" class="pb-5">
    <div class="container-lg">

        <div class="row">
            <div class="col-md-12">

                <div class="section-header d-flex flex-wrap justify-content-between my-4">

                    <h2 class="section-title">Main Course</h2>

                    <div class="d-flex align-items-center">
                        <a href="#" class="btn btn-primary rounded-1">View All</a>
                    </div>

                </div>

            </div>
        </div>

        <div class="row">
            <div class="col-md-12">

                <div class="product-grid row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-3 row-cols-xl-4 row-cols-xxl-5">

                    @foreach (var item in Model.Menus.Where(x => x.CategoryId == MenuCategory.MainCourse))
                    {
                        var soldOut = item.Stock <= 0;

                        <div class="col">

                            <div class="product-item border rounded p-3 @(soldOut ? "opacity-50 bg-light" : "")">

                                <figure>
                                    @if (!soldOut)
                                    {
                                        <a href="#">
                                            <img src="images/main1.png" class="tab-image">
                                        </a>
                                    }
                                    else
                                    {
                                        <img src="images/main1.png"
                                             class="tab-image"
                                             style="pointer-events:none;" />
                                    }
                                </figure>

                                <div class="d-flex flex-column text-center">

                                    <h3 class="fs-6 fw-normal">
                                        @item.MenuName
                                    </h3>

                                    <div class="d-flex justify-content-center align-items-center gap-2">

                                        <span class="text-dark fw-semibold">
                                            Rp @item.Price.ToString("#,##0").Replace(",", ".")
                                        </span>

                                    </div>

                                    <small class="mb-2">
                                        Stock: @item.Stock
                                    </small>

                                    <div class="button-area p-3 pt-0">

                                        @if (!soldOut)
                                        {
                                            <form asp-controller="UserOrder"
                                                  asp-action="AddToCart"
                                                  method="post">

                                                <input type="hidden"
                                                       name="menuId"
                                                       value="@item.MenuId" />

                                                <div class="row g-1 mt-2">

                                                    <div class="col-3">
                                                        <input type="number"
                                                               name="qty"
                                                               class="form-control"
                                                               value="1"
                                                               min="1" />
                                                    </div>

                                                    <div class="col-7">
                                                        <button type="submit"
                                                                class="btn btn-primary rounded-1">
                                                            Add to Cart
                                                        </button>
                                                    </div>

                                                </div>

                                            </form>
                                        }
                                        else
                                        {
                                            <button class="btn btn-secondary w-100" disabled>
                                                Stock Habis
                                            </button>
                                        }

                                    </div>

                                </div>

                            </div>

                        </div>
                    }

                </div>

            </div>
        </div>
    </div>
</section>


<!-- Cart -->
<div class="card p-3 mt-5">

    <h4>Cart</h4>
    @if (Model.Cart != null && Model.Cart.Any())
    {
        foreach (var item in Model.Cart)
        {
            <p>
                @item.MenuName
                x @item.Qty
                =
                Rp @item.Subtotal.ToString("#,##0").Replace(",", ".")
            </p>
        }

        <form asp-controller="UserOrder"
              asp-action="Checkout"
              method="post">

            <input name="tableId"
                   class="form-control mb-2" />

            <button type="submit"
                    class="btn btn-primary rounded-1">
                Checkout
            </button>

        </form>
    }
    else
    {
        <p>Cart kosong</p>
    }

</div>